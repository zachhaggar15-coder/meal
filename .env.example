# Copy this file to ".env" and paste your real OpenAI API key.
# Never commit .env to git.
OPENAI_API_KEY=your_openai_api_key_here

# Optional: choose a model. gpt-4o-mini is cheap and fast.
OPENAI_MODEL=gpt-4o-mini

# Feedback + waitlist emails are sent via Resend.
RESEND_API_KEY=your_resend_api_key_here

# ── MealPrep.org.uk email identity ────────────────────────────────────────────
# Where feedback is delivered, and the reply-to for outgoing emails.
MEALPREP_FEEDBACK_TO_EMAIL=mealprep.org.uk@proton.me
MEALPREP_REPLY_TO_EMAIL=mealprep.org.uk@proton.me
# "From" header. NOTE: Resend can only send from a domain you have verified.
# Verify mealprep.org.uk in Resend, then use e.g. "MealPrep.org.uk <hello@mealprep.org.uk>".
# Until then the code falls back to Resend's onboarding@resend.dev sender.
MEALPREP_FROM_EMAIL="MealPrep.org.uk <hello@mealprep.org.uk>"
MEALPREP_WAITLIST_FROM_EMAIL="MealPrep.org.uk <hello@mealprep.org.uk>"

# Legacy names still read as fallbacks (safe to remove once migrated):
# FEEDBACK_TO_EMAIL / FEEDBACK_FROM_EMAIL

# Optional: use a verified sending domain in Resend for production. If this is
# not set, /api/feedback uses Resend's onboarding sender for basic testing.
FEEDBACK_FROM_EMAIL="MealPrep Feedback <feedback@your-verified-domain.co.uk>"

# Alternative to Resend: send feedback to a private HTTPS webhook such as
# Make, Zapier, n8n or another inbox automation. This keeps the destination
# email out of the frontend and avoids exposing it in page source.
FEEDBACK_WEBHOOK_URL=https://your-private-webhook-url.example

# ── MealPrep+ waitlist (Supabase) ─────────────────────────────────────────────
# Server-side only. The service role key bypasses Row Level Security, so it must
# NEVER be exposed to the browser or committed. Frontend never sees these.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Shared secret that protects /admin and /api/admin-stats. Use a long random
# string, e.g. `openssl rand -hex 32`.
ADMIN_DASHBOARD_TOKEN=change_me_to_a_long_random_string
