# Copy this file to ".env" and paste your real OpenAI API key.
# Never commit .env to git.
OPENAI_API_KEY=your_openai_api_key_here

# Optional: choose a model. gpt-4o-mini is cheap and fast.
OPENAI_MODEL=gpt-4o-mini

# Feedback form emails are sent via Resend from /api/feedback.
RESEND_API_KEY=your_resend_api_key_here

# Optional: use a verified sending domain in Resend for production.
FEEDBACK_FROM_EMAIL="MealPrep Feedback <feedback@yourdomain.com>"
